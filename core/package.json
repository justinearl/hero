{
  "name": "@justinearl/hero-core",
  "version": "2.0.2",
  "repository": "git+https://github.com/justinearl/hero.git",
  "publishConfig": {
    "access": "public"
  },
  "description": "The core browser API used to run Hero",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    },
    "./package.json": "./package.json",
    "./lib/*": {
      "types": "./lib/*.d.ts",
      "require": "./lib/*.js"
    },
    "./dbs": "./dbs",
    "./dbs/*": {
      "types": "./dbs/*.d.ts",
      "require": "./dbs/*.js"
    },
    "./models/*": {
      "types": "./models/*.d.ts",
      "require": "./models/*.js"
    },
    "./connections/*": {
      "types": "./connections/*.d.ts",
      "require": "./connections/*.js"
    },
    "./apis/*": {
      "types": "./apis/*.d.ts",
      "require": "./apis/*.js"
    }
  },
  "dependencies": {
    "@justinearl/commons": "2.0.2",
    "@justinearl/default-browser-emulator": "2.0.2",
    "@justinearl/default-human-emulator": "2.0.2",
    "@justinearl/hero-interfaces": "2.0.2",
    "@justinearl/hero-plugin-utils": "2.0.2",
    "@justinearl/hero-timetravel": "2.0.2",
    "@justinearl/js-path": "2.0.2",
    "@justinearl/net": "2.0.2",
    "@justinearl/unblocked-agent": "2.0.2",
    "@justinearl/unblocked-agent-mitm": "2.0.2",
    "@justinearl/unblocked-specification": "2.0.2",
    "@ulixee/awaited-dom": "1.4.2",
    "better-sqlite3": "^11.1.2",
    "moment": "^2.29.4",
    "nanoid": "^3.3.11",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@justinearl/hero": "2.0.2",
    "@justinearl/hero-testing": "2.0.2",
    "@types/better-sqlite3": "^7.6.11",
    "@ulixee/chrome-app": "1.0.3"
  }
}
