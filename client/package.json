{
  "name": "@justinearl/hero",
  "version": "2.0.0-alpha.34",
  "repository": "git+https://github.com/justinearl/hero.git",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "description": "The client interface for Hero",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.mjs",
      "require": "./index.cjs"
    },
    "./lib/*": {
      "types": "./lib/*.d.ts",
      "default": "./lib/*.js",
      "require": "./lib/*.js"
    },
    "./connections/*": {
      "types": "./connections/*.d.ts",
      "default": "./connections/*.js",
      "require": "./connections/*.js"
    }
  },
  "dependencies": {
    "@ulixee/awaited-dom": "1.4.2",
    "@justinearl/commons": "2.0.0-alpha.34",
    "@justinearl/hero-interfaces": "2.0.0-alpha.34",
    "@justinearl/hero-plugin-utils": "2.0.0-alpha.34",
    "@justinearl/js-path": "2.0.0-alpha.34",
    "@justinearl/net": "2.0.0-alpha.34",
    "@justinearl/unblocked-specification": "2.0.0-alpha.34",
    "linkedom": "^0.14.11"
  },
  "devDependencies": {
    "@justinearl/hero-core": "2.0.0-alpha.34",
    "@justinearl/hero-testing": "2.0.0-alpha.34"
  }
}
